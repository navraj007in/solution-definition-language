{
  "name": "@sdl/core",
  "version": "1.1.0",
  "description": "Parser, validator, normalizer, and artifact generators for the Solution Design Language (SDL) — a YAML specification for software architecture decisions",
  "main": "dist/index.js",
  "module": "dist-esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-esm/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.esm.json",
    "build:cjs": "tsc",
    "build:esm": "tsc -p tsconfig.esm.json",
    "test": "node --test dist/__tests__/**/*.test.js",
    "pretest": "tsc"
  },
  "keywords": [
    "architecture",
    "sdl",
    "solution-design",
    "yaml",
    "validator",
    "generator",
    "infrastructure",
    "architecture-as-code"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/navraj007in/solution-definition-language.git",
    "directory": "packages/sdl"
  },
  "homepage": "https://github.com/navraj007in/solution-definition-language",
  "bugs": {
    "url": "https://github.com/navraj007in/solution-definition-language/issues"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  },
  "files": ["dist"],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
