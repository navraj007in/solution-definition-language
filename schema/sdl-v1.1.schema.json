{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://arch0.dev/schemas/sdl/v1.1/solution.schema.json",
  "title": "arch0 Solution Design Language v1.1",
  "description": "Machine-readable specification for software system architecture (SDL v1.1)",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^x-": {}
  },
  "required": [
    "sdlVersion",
    "solution",
    "architecture",
    "data"
  ],
  "properties": {
    "sdlVersion": {
      "type": "string",
      "enum": [
        "1.1"
      ],
      "description": "SDL schema version"
    },
    "solution": {
      "$ref": "#/$defs/SolutionMetadata"
    },
    "product": {
      "$ref": "#/$defs/ProductContext"
    },
    "architecture": {
      "$ref": "#/$defs/Architecture"
    },
    "auth": {
      "$ref": "#/$defs/Authentication"
    },
    "data": {
      "$ref": "#/$defs/DataLayer"
    },
    "integrations": {
      "$ref": "#/$defs/Integrations"
    },
    "nonFunctional": {
      "$ref": "#/$defs/NFRs"
    },
    "deployment": {
      "$ref": "#/$defs/Deployment"
    },
    "constraints": {
      "$ref": "#/$defs/Constraints"
    },
    "technicalDebt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TechDebt"
      }
    },
    "evolution": {
      "$ref": "#/$defs/Evolution"
    },
    "testing": {
      "$ref": "#/$defs/Testing"
    },
    "observability": {
      "$ref": "#/$defs/Observability"
    },
    "artifacts": {
      "$ref": "#/$defs/ArtifactConfig"
    },
    "techDebt": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TechDebt"
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "apis": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string"
              },
              "type": {
                "type": "string"
              },
              "owner": {
                "type": "string"
              }
            },
            "required": [
              "name"
            ]
          }
        }
      }
    },
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "entities": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "name": {
                "type": "string"
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            },
            "required": [
              "name"
            ]
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^x-": {}
      }
    },
    "slos": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^x-": {}
      }
    },
    "resilience": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^x-": {}
      }
    },
    "costs": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^x-": {}
      }
    },
    "backupDr": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^x-": {}
      }
    },
    "design": {
      "type": "object",
      "additionalProperties": true,
      "patternProperties": {
        "^x-": {}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "architecture"
        ],
        "properties": {
          "architecture": {
            "required": [
              "style"
            ],
            "properties": {
              "style": {
                "const": "microservices"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "architecture": {
            "required": [
              "services"
            ],
            "properties": {
              "services": {
                "minItems": 2,
                "errorMessage": "Microservices architecture requires at least 2 services"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "auth"
        ],
        "properties": {
          "auth": {
            "required": [
              "strategy"
            ],
            "properties": {
              "strategy": {
                "const": "oidc"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "auth": {
            "required": [
              "provider"
            ],
            "errorMessage": "OIDC strategy requires provider to be specified"
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "nonFunctional"
        ],
        "properties": {
          "nonFunctional": {
            "required": [
              "security"
            ],
            "properties": {
              "security": {
                "required": [
                  "pii"
                ],
                "properties": {
                  "pii": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "nonFunctional": {
            "properties": {
              "security": {
                "properties": {
                  "encryptionAtRest": {
                    "const": true,
                    "errorMessage": "PII data requires encryptionAtRest: true"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "deployment"
        ],
        "properties": {
          "deployment": {
            "required": [
              "infrastructure"
            ],
            "properties": {
              "infrastructure": {
                "required": [
                  "iac"
                ],
                "properties": {
                  "iac": {
                    "const": "cloudformation"
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "errorMessage": "CloudFormation can only be used with AWS (cloud: 'aws')",
        "not": {}
      }
    },
    {
      "if": {
        "required": [
          "data",
          "architecture"
        ],
        "properties": {
          "data": {
            "required": [
              "primaryDatabase"
            ],
            "properties": {
              "primaryDatabase": {
                "required": [
                  "type"
                ],
                "properties": {
                  "type": {
                    "const": "mongodb"
                  }
                }
              }
            }
          },
          "architecture": {
            "properties": {
              "projects": {
                "properties": {
                  "backend": {
                    "type": "array",
                    "contains": {
                      "type": "object",
                      "required": [
                        "orm"
                      ],
                      "properties": {
                        "orm": {
                          "const": "ef-core"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "errorMessage": "MongoDB cannot be used with Entity Framework Core - use Mongoose instead",
        "not": {}
      }
    }
  ],
  "$defs": {
    "SolutionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "name",
        "description",
        "stage"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 50,
          "pattern": "^[a-zA-Z0-9\\s\\-]+$",
          "description": "Solution name"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200,
          "description": "One-line pitch"
        },
        "stage": {
          "type": "string",
          "enum": [
            "MVP",
            "Growth",
            "Enterprise"
          ],
          "description": "Current product stage"
        },
        "domain": {
          "type": "string",
          "description": "Primary domain",
          "pattern": "^[A-Za-z0-9.-]+$"
        },
        "regions": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "required": [
            "primary"
          ],
          "properties": {
            "primary": {
              "type": "string",
              "description": "Primary deployment region"
            },
            "secondary": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "DR/multi-region deployments"
            }
          }
        },
        "repository": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "org": {
              "type": "string"
            },
            "naming": {
              "type": "string"
            }
          }
        }
      }
    },
    "ProductContext": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "personas"
      ],
      "properties": {
        "personas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
              "^x-": {}
            },
            "required": [
              "name",
              "goals"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "goals": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "accessLevel": {
                "type": "string",
                "enum": [
                  "public",
                  "authenticated",
                  "admin"
                ]
              }
            }
          }
        },
        "coreFlows": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
              "^x-": {}
            },
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "priority": {
                "type": "string",
                "enum": [
                  "critical",
                  "high",
                  "medium",
                  "low"
                ]
              }
            }
          }
        },
        "valueProposition": {
          "type": "string"
        }
      }
    },
    "Architecture": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "style",
        "projects"
      ],
      "properties": {
        "style": {
          "type": "string",
          "enum": [
            "modular-monolith",
            "microservices",
            "serverless"
          ]
        },
        "projects": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "frontend": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/FrontendProject"
              }
            },
            "backend": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/BackendProject"
              }
            },
            "mobile": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/MobileProject"
              }
            }
          }
        },
        "services": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Service"
          }
        },
        "sharedLibraries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "patternProperties": {
              "^x-": {}
            },
            "properties": {
              "name": {
                "type": "string"
              },
              "language": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "FrontendProject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "name",
        "framework"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "web",
            "mobile-web",
            "admin"
          ],
          "default": "web"
        },
        "framework": {
          "type": "string",
          "enum": [
            "nextjs",
            "react",
            "vue",
            "angular",
            "svelte",
            "solid"
          ]
        },
        "rendering": {
          "type": "string",
          "enum": [
            "ssr",
            "ssg",
            "spa"
          ]
        },
        "stateManagement": {
          "type": "string",
          "enum": [
            "context",
            "redux",
            "zustand",
            "mobx",
            "none"
          ]
        },
        "styling": {
          "type": "string",
          "enum": [
            "tailwind",
            "css-modules",
            "styled-components",
            "sass",
            "emotion"
          ]
        }
      }
    },
    "BackendProject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "name",
        "framework"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "backend",
            "worker",
            "function"
          ],
          "default": "backend"
        },
        "framework": {
          "type": "string",
          "enum": [
            "dotnet-8",
            "nodejs",
            "python-fastapi",
            "go",
            "java-spring",
            "ruby-rails",
            "php-laravel"
          ]
        },
        "apiStyle": {
          "type": "string",
          "enum": [
            "rest",
            "graphql",
            "grpc",
            "mixed"
          ]
        },
        "orm": {
          "type": "string",
          "enum": [
            "ef-core",
            "prisma",
            "typeorm",
            "sqlalchemy",
            "gorm",
            "sequelize",
            "mongoose"
          ]
        },
        "apiVersioning": {
          "type": "string",
          "enum": [
            "url-prefix",
            "header",
            "query-param",
            "none"
          ]
        }
      }
    },
    "MobileProject": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "name",
        "platform",
        "framework"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "platform": {
          "type": "string",
          "enum": [
            "ios",
            "android",
            "cross-platform"
          ]
        },
        "framework": {
          "type": "string",
          "enum": [
            "react-native",
            "flutter",
            "swift",
            "kotlin",
            "ionic"
          ]
        }
      }
    },
    "Service": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "name",
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "backend",
            "worker",
            "function",
            "api-gateway"
          ]
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "exposes": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "http": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^x-": {}
              },
              "properties": {
                "basePath": {
                  "type": "string"
                },
                "openapi": {
                  "type": "boolean"
                }
              }
            },
            "grpc": {
              "type": "boolean"
            },
            "graphql": {
              "type": "boolean"
            }
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Authentication": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "strategy"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "enum": [
            "oidc",
            "passwordless",
            "magic-link",
            "api-key",
            "none"
          ]
        },
        "provider": {
          "type": "string",
          "enum": [
            "cognito",
            "auth0",
            "entra-id",
            "entra-id-b2c",
            "firebase",
            "supabase",
            "clerk",
            "custom"
          ]
        },
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "sessions": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "accessToken": {
              "type": "string",
              "enum": [
                "jwt",
                "opaque"
              ]
            },
            "refreshToken": {
              "type": "boolean"
            },
            "ttl": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^x-": {}
              },
              "properties": {
                "access": {
                  "type": "string"
                },
                "refresh": {
                  "type": "string"
                }
              }
            }
          }
        },
        "mfa": {
          "type": "boolean"
        },
        "socialProviders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "google",
              "github",
              "microsoft",
              "apple",
              "facebook",
              "twitter"
            ]
          }
        }
      }
    },
    "DataLayer": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "primaryDatabase"
      ],
      "properties": {
        "primaryDatabase": {
          "$ref": "#/$defs/Database"
        },
        "secondaryDatabases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Database"
          }
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "blobs": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^x-": {}
              },
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": [
                    "azure-blob",
                    "s3",
                    "gcs",
                    "cloudflare-r2"
                  ]
                },
                "public": {
                  "type": "boolean"
                }
              }
            },
            "files": {
              "type": "object",
              "additionalProperties": false,
              "patternProperties": {
                "^x-": {}
              },
              "properties": {
                "provider": {
                  "type": "string",
                  "enum": [
                    "azure-blob",
                    "s3",
                    "gcs",
                    "cloudflare-r2"
                  ]
                }
              }
            }
          }
        },
        "cache": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "redis",
                "memcached",
                "none"
              ]
            },
            "required": {
              "type": "boolean"
            },
            "useCase": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "session",
                  "api",
                  "query"
                ]
              }
            }
          }
        },
        "queues": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "rabbitmq",
                "azure-service-bus",
                "sqs",
                "kafka",
                "redis"
              ]
            },
            "useCase": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "async-jobs",
                  "event-streaming",
                  "notifications"
                ]
              }
            }
          }
        },
        "search": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "elasticsearch",
                "algolia",
                "typesense",
                "azure-search",
                "meilisearch",
                "pinecone",
                "qdrant",
                "weaviate"
              ]
            }
          }
        }
      }
    },
    "Database": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "required": [
        "type",
        "hosting"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "postgres",
            "mysql",
            "sqlserver",
            "mongodb",
            "dynamodb",
            "cockroachdb",
            "planetscale"
          ]
        },
        "hosting": {
          "type": "string",
          "enum": [
            "managed",
            "self-hosted",
            "serverless"
          ]
        },
        "name": {
          "type": "string"
        },
        "size": {
          "type": "string",
          "enum": [
            "small",
            "medium",
            "large"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "primary",
            "read-replica",
            "analytics"
          ]
        }
      }
    },
    "Integrations": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^x-": {}
      },
      "properties": {
        "payments": {
          "type": "object",
          "additionalProperties": false,
          "patternProperties": {
            "^x-": {}
          },
          "properties": {
            "provider": {
              "type": "string",
              "enum": [
                "stripe",
                "paypal",
                "square",
                "adyen",
                "braintree"
              ]
            },
            "mode": {
              "type": "string",
              "enum": [
                "subscriptions",
